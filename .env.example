# YoRHa API Server — Environment Variables
# Copy this file to .env and fill in your values

# SoundCloud API client_id
# How to get one:
#   Option A (official): Register at https://developers.soundcloud.com/
#                        Requires SoundCloud Artist Pro subscription.
#   Option B (dev-only): Open soundcloud.com in Chrome → DevTools → Network tab
#                        Filter by "client_id" → copy the value from any SC API request URL.
#                        NOTE: unofficial, may stop working. Use Option A for production.
SOUNDCLOUD_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Server port (optional — defaults to 3001)
PORT=3001

# MongoDB Connection URI (local or cloud cluster)
MONGODB_URI=mongodb://127.0.0.1:27017/yorha_portfolio

# Secret used to sign admin session tokens (HMAC-SHA256).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If unset, the server falls back to a random secret generated at boot,
# which invalidates all admin sessions on every restart.
SESSION_SECRET=
